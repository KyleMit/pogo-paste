<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>PoGo Paste</title>
  {% set logoSvg %}{% include 'icons/logo.svg' %}{% endset %}
  <link rel="icon" href="data:image/svg+xml,{{ logoSvg | trim | replace("&amp;", "&amp;amp;") | safe }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>{% include "styles/style.css" %}</style>
</head>
<body>
  <main>
    <h1 class="logo-title">
      <img src="static/pogo-paste.png" alt="PoGo Paste" class="logo-image" />
    </h1>

    <div id="toast" class="toast hidden"></div>

    <div class="content-wrapper">
      {% include "views/toolbar.njk" %}
      <div class="sections-viewport">
        {% include "views/symbols-container.njk" %}
        {% include "views/search-container.njk" %}
      </div>
    </div>
  </main>

  <footer>
    <a href="https://github.com/KyleMit/pogo-paste" target="_blank" rel="noopener noreferrer">
      View on GitHub
    </a>
  </footer>

  <script>
    {% include "scripts/toggle.js" %}
    {% include "scripts/copy.js" %}
  </script>
  
</body>
</html>
