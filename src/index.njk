<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>PoGo Paste</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧢</text></svg>">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>{% include "style.css" %}</style>
</head>
<body>
  <main>
    <h1 class="pokemon-text archivo-black-regular">PoGo Paste</h1>

    <div id="toast" class="toast hidden"></div>

    <div class="content-wrapper">
      <div class="view-toggle">
        <button id="listViewBtn" class="view-btn" data-view="list" aria-label="List view">
          {% include "list-view.svg" %}
        </button>
        <button id="gridViewBtn" class="view-btn" data-view="grid" aria-label="Grid view">
          {% include "grid-view.svg" %}
        </button>
      </div>

      <div class="cards-container">
      {% for group in symbols %}
        <div class="symbol-card">
          <h2 class="archivo-black-regular">{{ group.name }}</h2>
          {% if group.name == "Numbers" %}
            <div class="numbers-grid">
              {% for item in group.items %}
                <input type="button" value="{{ item.symbol }}" class="copy-btn numbers-btn" title="{{ item.name }}" />
              {% endfor %}
            </div>
          {% else %}
            <div class="symbol-items">
              {% for item in group.items %}
                <div class="symbol-row">
                  <div class="symbol-label">
                    <div class="type-container">
                      {% if item.icon %}
                        <img src="static/images/{{ item.icon }}" alt="{{ item.name }} icon" class="type-icon">
                      {% endif %}
                      <div class="{{item.className}}">
                        {{ item.name }}
                      </div>
                    </div>
                  </div>
                  <div class="symbol-button">
                    <input type="button" value="{{ item.symbol }}" class="copy-btn" />
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
      </div>
    </div>
  </main>

  <footer>
    <a href="https://github.com/KyleMit/pogo-paste" target="_blank" rel="noopener noreferrer">
      View on GitHub
    </a>
  </footer>

  <script>{% include "script.js" %}</script>
</body>
</html>
