<div class="toolbar">
  <div class="section-toggle" data-toggle-storage-key="pogo-paste-section" data-toggle-default="symbols">
    <button class="section-btn" data-toggle-value="symbols" data-toggle-body-class="" aria-label="Symbols view">
      {% include "icons/symbol.svg" %}
    </button>
    <button class="section-btn" data-toggle-value="search" data-toggle-body-class="section-search" aria-label="Search strings view">
      {% include "icons/search.svg" %}
    </button>
  </div>
  <div class="view-toggle" data-toggle-storage-key="pogo-paste-view-mode" data-toggle-default="list">
    <button class="view-btn" data-toggle-value="list" data-toggle-body-class="" aria-label="List view">
      {% include "icons/list-view.svg" %}
    </button>
    <button class="view-btn" data-toggle-value="grid" data-toggle-body-class="grid-view" aria-label="Grid view">
      {% include "icons/grid-view.svg" %}
    </button>
  </div>
</div>
