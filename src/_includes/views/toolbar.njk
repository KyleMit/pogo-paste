<div class="toolbar">
  <div class="section-toggle" data-toggle-storage-key="pogo-paste-section" data-toggle-default="symbols" data-toggle-class-prefix="section-">
    <button class="section-btn" data-toggle-value="symbols" aria-label="Symbols view">
      {% include "icons/symbol.svg" %}
    </button>
    <button class="section-btn" data-toggle-value="search" aria-label="Search strings view">
      {% include "icons/search.svg" %}
    </button>
  </div>
  <div class="view-toggle" data-toggle-storage-key="pogo-paste-view-mode" data-toggle-default="list" data-toggle-class-prefix="view-">
    <button class="view-btn" data-toggle-value="list" aria-label="List view">
      {% include "icons/list-view.svg" %}
    </button>
    <button class="view-btn" data-toggle-value="grid" aria-label="Grid view">
      {% include "icons/grid-view.svg" %}
    </button>
  </div>
</div>
